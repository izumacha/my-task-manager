{
  "schema": {
    "description": "言語非依存の繰り返し（リカレンス）契約ケース。reminder.recurrence.next_occurrence(completed_at, unit, interval) の入力と期待出力を固定する。各プラットフォーム実装はこの契約に一致しなければならない（1コア全プラットフォーム差異ゼロの真実の源）。",
    "datetime_format": "%Y-%m-%dT%H:%M:%S",
    "note": "completed_at / expected はタイムゾーンを持たない naive datetime の ISO 文字列。%-d 等の非移植指定子は含めない。expected が null の場合は『繰り返しなし（次回タスクを生成しない）』を表す。interval は下限 1 にクランプされ上限クランプはない（実装 add_period の max(MIN_INTERVAL, interval) に準拠）。",
    "fields": {
      "name": "ケースの識別名（人間可読）",
      "completed_at": "完了時点（次回計算の起点）の ISO 文字列",
      "unit": "繰り返し単位。none / daily / weekly / monthly / yearly のいずれか",
      "interval": "繰り返し間隔（整数）。0 や負値は 1 として扱われる",
      "expected": "next_occurrence の期待出力（ISO 文字列）。none の場合は null"
    }
  },
  "cases": [
    {
      "name": "daily_simple",
      "completed_at": "2026-06-06T22:15:00",
      "unit": "daily",
      "interval": 1,
      "expected": "2026-06-07T22:15:00"
    },
    {
      "name": "daily_multiple_interval",
      "completed_at": "2026-06-06T09:30:00",
      "unit": "daily",
      "interval": 10,
      "expected": "2026-06-16T09:30:00"
    },
    {
      "name": "weekly_simple",
      "completed_at": "2026-06-06T07:00:00",
      "unit": "weekly",
      "interval": 1,
      "expected": "2026-06-13T07:00:00"
    },
    {
      "name": "weekly_two_intervals",
      "completed_at": "2026-06-06T09:30:00",
      "unit": "weekly",
      "interval": 2,
      "expected": "2026-06-20T09:30:00"
    },
    {
      "name": "monthly_simple_two_months",
      "completed_at": "2026-06-06T07:00:00",
      "unit": "monthly",
      "interval": 2,
      "expected": "2026-08-06T07:00:00"
    },
    {
      "name": "yearly_simple",
      "completed_at": "2026-06-06T07:00:00",
      "unit": "yearly",
      "interval": 1,
      "expected": "2027-06-06T07:00:00"
    },
    {
      "name": "none_returns_null",
      "completed_at": "2026-06-06T09:00:00",
      "unit": "none",
      "interval": 1,
      "expected": null
    },
    {
      "name": "month_end_clamp_jan31_to_feb28_common_year",
      "completed_at": "2026-01-31T08:00:00",
      "unit": "monthly",
      "interval": 1,
      "expected": "2026-02-28T08:00:00"
    },
    {
      "name": "month_end_clamp_jan31_to_feb29_leap_year",
      "completed_at": "2028-01-31T08:00:00",
      "unit": "monthly",
      "interval": 1,
      "expected": "2028-02-29T08:00:00"
    },
    {
      "name": "month_end_clamp_mar31_to_apr30",
      "completed_at": "2026-03-31T09:00:00",
      "unit": "monthly",
      "interval": 1,
      "expected": "2026-04-30T09:00:00"
    },
    {
      "name": "leap_day_feb29_plus_one_year_to_feb28",
      "completed_at": "2028-02-29T12:00:00",
      "unit": "yearly",
      "interval": 1,
      "expected": "2029-02-28T12:00:00"
    },
    {
      "name": "interval_zero_clamped_to_one_daily",
      "completed_at": "2026-06-06T09:30:00",
      "unit": "daily",
      "interval": 0,
      "expected": "2026-06-07T09:30:00"
    },
    {
      "name": "interval_negative_clamped_to_one_daily",
      "completed_at": "2026-06-06T09:30:00",
      "unit": "daily",
      "interval": -5,
      "expected": "2026-06-07T09:30:00"
    },
    {
      "name": "interval_100_no_upper_clamp_daily",
      "completed_at": "2026-06-06T09:30:00",
      "unit": "daily",
      "interval": 100,
      "expected": "2026-09-14T09:30:00"
    },
    {
      "name": "interval_99_monthly_far_future",
      "completed_at": "2026-01-15T10:00:00",
      "unit": "monthly",
      "interval": 99,
      "expected": "2034-04-15T10:00:00"
    },
    {
      "name": "monthly_crosses_year",
      "completed_at": "2026-06-06T09:30:00",
      "unit": "monthly",
      "interval": 8,
      "expected": "2027-02-06T09:30:00"
    },
    {
      "name": "midnight_daily_crosses_month",
      "completed_at": "2026-01-31T23:59:00",
      "unit": "daily",
      "interval": 1,
      "expected": "2026-02-01T23:59:00"
    },
    {
      "name": "early_morning_weekly_crosses_month",
      "completed_at": "2026-06-29T00:30:00",
      "unit": "weekly",
      "interval": 1,
      "expected": "2026-07-06T00:30:00"
    },
    {
      "name": "monthly_dec31_to_jan31_next_year",
      "completed_at": "2026-12-31T09:00:00",
      "unit": "monthly",
      "interval": 1,
      "expected": "2027-01-31T09:00:00"
    },
    {
      "name": "yearly_three_intervals",
      "completed_at": "2026-06-06T09:30:00",
      "unit": "yearly",
      "interval": 3,
      "expected": "2029-06-06T09:30:00"
    }
  ]
}
